# Verlytax OS v4 — Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env to git.

# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=change_me_to_a_random_64_char_string
CEO_PHONE=+1XXXXXXXXXX        # Delta's whitelisted phone number

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./verlytax.db
# For Postgres on Railway: DATABASE_URL=postgresql+asyncpg://user:pass@host/db

# ── Claude / Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio (Nova SMS + Retell voice) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
RETELL_API_KEY=key_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# One Retell agent ID per voice persona — create each in your Retell dashboard
RETELL_AGENT_ID_ERIN=agent_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Inbound carrier dispatch calls → Erin
RETELL_AGENT_ID_AVA=agent_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx    # Inbound new lead qualification → Ava
RETELL_AGENT_ID_ZARA=agent_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Outbound support escalation calls → Zara

# ── Stripe (fee collection) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── FMCSA ────────────────────────────────────────────────────────────────────
FMCSA_API_KEY=your_fmcsa_api_key

# ── DAT (load board carrier search — leave blank until DAT One API access obtained) ──
DAT_API_KEY=                     # DAT One API bearer token — activates automatically when set

# ── Telegram (CEO interface — parallel to Twilio, or full replacement if Twilio dropped) ──
# Step 1: Create a bot via @BotFather on Telegram → get TELEGRAM_BOT_TOKEN
# Step 2: Message your bot once, then GET https://api.telegram.org/bot{TOKEN}/getUpdates
#         to find your chat ID → set as TELEGRAM_CEO_CHAT_ID
# Step 3: Register webhook (run once after deploy):
#   POST https://api.telegram.org/bot{TOKEN}/setWebhook
#   Body: {"url": "https://your-railway-url/webhooks/telegram", "secret_token": "{TELEGRAM_WEBHOOK_SECRET}"}
TELEGRAM_BOT_TOKEN=                    # From @BotFather
TELEGRAM_CEO_CHAT_ID=                  # Delta's personal chat ID with the bot (numbers only)
TELEGRAM_WEBHOOK_SECRET=change_me_to_a_random_token   # Any random string — used to verify inbound updates

# ── Internal auth ────────────────────────────────────────────────────────────
INTERNAL_TOKEN=change_me_to_a_random_token

# ── Google Drive (Brain back-office automation) ───────────────────────────────
# Service account JSON — paste raw JSON string OR base64-encode it first
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Root folder ID from the Google Drive URL of your DispatchClients folder
GOOGLE_DRIVE_ROOT_FOLDER_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ
